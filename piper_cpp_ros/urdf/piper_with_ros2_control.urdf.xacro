<?xml version="1.0"?>
<!--
  Top-level xacro that wraps the existing piper_description URDF and adds the ros2_control
  block from `piper.ros2_control.xacro`.

  If you maintain your own piper xacro, copy this pattern: include the description, include
  this package's ros2_control snippet, and call <xacro:piper_ros2_control/>.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="piper">

  <!-- Description geometry/links/joints from the upstream piper_description package. -->
  <xacro:include filename="$(find piper_description)/urdf/piper_no_gripper_description.xacro"/>

  <!-- ros2_control hardware interface block. -->
  <xacro:include filename="$(find piper_cpp_ros)/urdf/piper.ros2_control.xacro"/>

  <xacro:arg name="can_interface" default="can0"/>
  <xacro:arg name="speed_pct" default="30"/>
  <xacro:arg name="go_to_zero_on_activate" default="true"/>

  <xacro:piper_ros2_control
      can_interface="$(arg can_interface)"
      speed_pct="$(arg speed_pct)"
      go_to_zero_on_activate="$(arg go_to_zero_on_activate)"/>
</robot>
