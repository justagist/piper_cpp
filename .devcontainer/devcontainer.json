{
    "name": "piper_cpp (ROS 2 Jazzy)",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    // We’ll do dev work in /ws, which is a colcon workspace
    "workspaceFolder": "/ws",
    // Bind your local repo into the container at /ws/src/piper_cpp
    "workspaceMount": "source=${localWorkspaceFolder},target=/ws/src/piper_cpp,type=bind",
    // Keep the Dockerfile’s entrypoint so ROS env is sourced automatically
    "overrideCommand": true,
    "postStartCommand": "bash",
    // Helpful capabilities & mounts for SocketCAN work
    "runArgs": [
        "--net=host",
        "--cap-add=NET_ADMIN",
        "--privileged",
        "-v",
        "/lib/modules:/lib/modules:ro"
    ],
    "containerEnv": {
        "ROS_DISTRO": "jazzy"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools"
            },
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "ms-iot.vscode-ros",
                "ms-python.python"
            ]
        }
    },
    "remoteUser": "root"
}