<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="piper">

  <!--
    Gripper-enabled SRDF. Defines:
      - the `manipulator` planning group (kinematic chain base_link -> link6),
      - the `gripper` planning group (chain gripper_base -> link7), used as the
        end-effector for `manipulator`,
      - named group states (`home`, `ready`, `open`, `close`),
      - virtual joint anchoring the arm to `world`,
      - adjacent-link self-collision exclusions for both arm and gripper.

    Companion to `piper.srdf.xacro` (no gripper). This one assumes the URDF was built
    from `piper_with_gripper_with_ros2_control.urdf.xacro`, which includes the full
    piper_description (with joint7/joint8).
  -->

  <group name="manipulator">
    <chain base_link="base_link" tip_link="link6"/>
  </group>

  <group name="gripper">
    <chain base_link="gripper_base" tip_link="link7"/>
  </group>

  <end_effector name="piper_gripper" parent_link="link6" group="gripper" parent_group="manipulator"/>

  <!-- All arm joints zero. Matches the `piper_go_zero` / `setGripperZero` reference pose. -->
  <group_state name="home" group="manipulator">
    <joint name="joint1" value="0"/>
    <joint name="joint2" value="0"/>
    <joint name="joint3" value="0"/>
    <joint name="joint4" value="0"/>
    <joint name="joint5" value="0"/>
    <joint name="joint6" value="0"/>
  </group_state>

  <!-- A small pose that lifts the elbow up off the home pose, useful for safe motion start. -->
  <group_state name="ready" group="manipulator">
    <joint name="joint1" value="0"/>
    <joint name="joint2" value="0.5"/>
    <joint name="joint3" value="-0.8"/>
    <joint name="joint4" value="0"/>
    <joint name="joint5" value="0.4"/>
    <joint name="joint6" value="0"/>
  </group_state>

  <group_state name="open" group="gripper">
    <joint name="joint7" value="0.035"/>
  </group_state>

  <group_state name="close" group="gripper">
    <joint name="joint7" value="0"/>
  </group_state>

  <!-- Anchor the arm base to the world frame so MoveIt has a fixed planning frame. -->
  <virtual_joint name="world_to_base" type="fixed" parent_frame="world" child_link="base_link"/>

  <!-- Adjacent-link exclusions for the arm (planner deadlocks otherwise). -->
  <disable_collisions link1="base_link" link2="link1" reason="Adjacent"/>
  <disable_collisions link1="link1" link2="link2" reason="Adjacent"/>
  <disable_collisions link1="link2" link2="link3" reason="Adjacent"/>
  <disable_collisions link1="link3" link2="link4" reason="Adjacent"/>
  <disable_collisions link1="link4" link2="link5" reason="Adjacent"/>
  <disable_collisions link1="link5" link2="link6" reason="Adjacent"/>

  <!-- Gripper adjacencies. gripper_base attaches to link6; link7/link8 are the fingers. -->
  <disable_collisions link1="link6" link2="gripper_base" reason="Adjacent"/>
  <disable_collisions link1="gripper_base" link2="link7" reason="Adjacent"/>
  <disable_collisions link1="gripper_base" link2="link8" reason="Adjacent"/>
  <disable_collisions link1="link7" link2="link8" reason="Default"/>

</robot>
